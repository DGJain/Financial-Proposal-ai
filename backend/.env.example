# Backend environment — copy to `.env`. Air-gapped: all endpoints are in-cluster.

ENVIRONMENT=local
AIR_GAPPED=true

# --- PostgreSQL (system of record) ---
POSTGRES_DSN=postgresql+asyncpg://fpp:fpp@localhost:5432/fpp

# --- Redis (cache / queue / sessions) ---
REDIS_DSN=redis://localhost:6379/0

# --- ChromaDB (3 collections) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- Object storage (S3-compatible / MinIO) ---
OBJECT_STORAGE_ENDPOINT_URL=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin

# --- AI plane ---
# provider: `slm` (required in production) or `claude` (prototype/eval only)
AI_PROVIDER=claude
AI_EMBEDDING_MODEL_VERSION=local-embed-v1
# Prototype-only; ignored when AI_PROVIDER=slm:
AI_CLAUDE_MODEL=claude-sonnet-4-6
AI_CLAUDE_API_KEY=
